generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Direction {
  YGN_TO_BKK
  BKK_TO_YGN
}

/// A carrier's posted trip with spare luggage capacity (YGN <-> BKK only).
model Trip {
  id               String    @id @default(uuid()) @db.Uuid
  /// Supabase auth.users id of the owner (logical ref; no DB-level FK across schemas).
  userId           String    @map("user_id") @db.Uuid
  carrierName      String    @map("carrier_name")
  direction        Direction
  travelDate       DateTime  @map("travel_date") @db.Date
  availableKg      Decimal   @map("available_kg") @db.Decimal(4, 1)
  pricePerKg       Decimal?  @map("price_per_kg") @db.Decimal(10, 2)
  itemRestrictions String?   @map("item_restrictions")

  // Contact — telegram required, rest optional
  telegram String
  facebook String?
  viber    String?
  whatsapp String?

  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// = travelDate end-of-day; browse filters expiresAt > now()
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)

  @@index([direction, expiresAt])
  @@index([userId])
  @@map("trips")
}
